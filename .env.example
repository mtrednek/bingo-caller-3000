# Database Configuration
DATABASE_URL="file:./prisma/dev.db"

# NextAuth.js Configuration
# IMPORTANT: Generate a secure secret for production!
# You can generate one with: openssl rand -base64 32
NEXTAUTH_SECRET="CHANGE-THIS-TO-A-SECURE-RANDOM-STRING"
NEXTAUTH_URL="http://localhost:3000"

# Application URL
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Socket.IO Configuration (optional - for real-time features)
NEXT_PUBLIC_SOCKET_URL="http://localhost:3001"
SOCKET_PORT=3001

# Admin User Setup (used during initial seed only)
# These are ONLY used when first seeding the database
# After that, change your password through the application!
ADMIN_EMAIL="admin@bingo.local"
ADMIN_USERNAME="admin"
ADMIN_PASSWORD="CHANGE-THIS-PASSWORD"

# Caller User Setup (optional)
CALLER_EMAIL="caller@bingo.local"
CALLER_USERNAME="caller"
CALLER_PASSWORD="CHANGE-THIS-PASSWORD"
