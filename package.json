{
  "name": "bingo-caller",
  "version": "1.0.2",
  "private": true,
  "scripts": {
    "dev": "concurrently \"npm run next:dev\" \"npm run socket:dev\"",
    "dev:next": "next dev",
    "next:dev": "next dev",
    "socket:dev": "tsx server/index.ts",
    "build": "next build",
    "build:socket": "tsc server/index.ts --outDir dist --rootDir . --target ES2020 --module commonjs --esModuleInterop --resolveJsonModule",
    "build:standalone": "npm run build && node scripts/copy-static-assets.js && npm run build:socket",
    "start": "concurrently \"npm run next:start\" \"npm run socket:start\"",
    "start:launcher": "node launcher.js",
    "next:start": "next start",
    "socket:start": "node dist/server/index.js",
    "lint": "next lint",
    "package": "node scripts/prepare-package.js",
    "package:all": "npm run package:win && npm run package:mac && npm run package:linux",
    "package:win": "caxa --input . --output \"dist-packages/bingo-caller-windows.exe\" -- \"{{caxa}}/node_modules/.bin/node\" \"{{caxa}}/launcher.js\"",
    "package:mac": "caxa --input . --output \"dist-packages/bingo-caller-macos\" -- \"{{caxa}}/node_modules/.bin/node\" \"{{caxa}}/launcher.js\"",
    "package:linux": "caxa --input . --output \"dist-packages/bingo-caller-linux\" -- \"{{caxa}}/node_modules/.bin/node\" \"{{caxa}}/launcher.js\"",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "db:seed": "tsx prisma/seed.ts",
    "db:export-patterns": "tsx scripts/export-patterns.ts",
    "db:fix": "node scripts/fix-db-integrity.js",
    "db:test": "node scripts/test-db.js"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.10.0",
    "@prisma/client": "^6.14.0",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-icons": "^1.3.2",
    "@radix-ui/react-label": "^2.1.7",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-toast": "^1.2.15",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@types/bcryptjs": "^2.4.6",
    "@types/express": "^5.0.3",
    "@types/node": "^24.3.0",
    "@types/react": "^19.1.11",
    "@types/react-dom": "^19.1.7",
    "autoprefixer": "^10.4.21",
    "bcryptjs": "^3.0.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "concurrently": "^9.2.0",
    "date-fns": "^4.1.0",
    "eslint": "^9.34.0",
    "eslint-config-next": "^15.5.0",
    "express": "^5.1.0",
    "lucide-react": "^0.541.0",
    "next": "^15.5.0",
    "next-auth": "^5.0.0-beta.29",
    "postcss": "^8.5.6",
    "prisma": "^6.14.0",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "socket.io": "^4.8.1",
    "socket.io-client": "^4.8.1",
    "sqlite3": "^5.1.7",
    "tailwind-merge": "^3.3.1",
    "tailwindcss": "^3.4.17",
    "tailwindcss-animate": "^1.0.7",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2",
    "zustand": "^5.0.8"
  },
  "devDependencies": {
    "@types/node": "^24.3.0",
    "@types/react": "^19.1.11",
    "@types/react-dom": "^19.1.7",
    "caxa": "^3.0.1"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  }
}
